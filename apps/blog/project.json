{
  "name": "blog",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/blog/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/angular:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/blog",
        "index": "apps/blog/src/index.html",
        "browser": "apps/blog/src/main.ts",
        "tsConfig": "apps/blog/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/blog/public"
          },
          {
            "glob": "**/{swagger-ui.css,swagger-ui-bundle.js,swagger-ui-standalone-preset.js,favicon-32x32.png,favicon-16x16.png}",
            "input": "./node_modules/swagger-ui-dist",
            "output": "./api/api"
          }
        ],
        "styles": ["apps/blog/src/styles.scss"],
        "scripts": [],
        "server": "apps/blog/src/main.server.ts",
        "externalDependencies": [
          "node_modules/*",
          "class-transformer",
          "class-validator",
          "amqplib",
          "amqp-connection-manager",
          "@grpc/grpc-js",
          "@grpc/proto-loader",
          "kafkajs",
          "mqtt",
          "nats",
          "ioredis"
        ],
        "ssr": {
          "entry": "apps/blog/server.ts"
        },
        "outputMode": "server"
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all",
          "sourceMap": true
        },
        "static": {
          "outputMode": "static",
          "prerender": true,
          "outputHashing": "all",
          "sourceMap": false,
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ]
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/angular:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "blog:build:production"
        },
        "development": {
          "port": 4201,
          "buildTarget": "blog:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "blog:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/vite:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "../coverage/blog"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "blog:build",
        "port": 4200,
        "staticFilePath": "dist/blog/browser",
        "spa": true
      }
    }
  }
}
